{
  "name": "riotbus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run banners:build",
    "dev": "next dev",
    "prebuild": "npm run banners:build",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepreview:cloudflare": "npm run banners:build",
    "preview:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "predeploy:cloudflare": "npm run banners:build",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "pretypecheck": "npm run banners:build",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "banners:build": "node scripts/build-banners.mjs",
    "rag:chunks": "node scripts/rag-build-chunks.mjs",
    "rag:embed": "node scripts/rag-embed.mjs",
    "rag:search": "node scripts/rag-search.mjs",
    "rag:chroma": "node scripts/rag-chroma-push.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.23.24",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.8.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^4.20.0"
  }
}
